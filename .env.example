# ── LLM Gateway ──────────────────────────────────────────────────────────────
# Mode: "portkey" (default, recommended) or "direct" (no Portkey account)
LLM_MODE=portkey

# Portkey mode — get keys at portkey.ai
PORTKEY_API_KEY=pk-...
PORTKEY_CONFIG=cf-...

# Direct mode — set LLM_MODE=direct and fill one of these blocks
# LLM_MODE=direct
# LLM_PROVIDER=google          # or "openai"
# LLM_MODEL_DIRECT=gemini-2.5-flash
# GOOGLE_API_KEY=AIza...       # from aistudio.google.com
# OPENAI_API_KEY=sk-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# "local" uses sentence-transformers/all-MiniLM-L6-v2 (default, free)
# "openai" uses text-embedding-3-small (requires OPENAI_API_KEY)
EMBEDDING_MODE=local
# OPENAI_API_KEY=sk-...

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Mock server (tests / CI) ──────────────────────────────────────────────────
MOCK_SERVER_URL=http://localhost:8888
